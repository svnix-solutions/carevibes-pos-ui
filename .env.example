# ERPNext instance URL
ERPNEXT_URL=https://carevibes.m.frappe.cloud

# carevibes-auth-ui bridge URL
BRIDGE_URL=https://carevibes-auth.netlify.app

# POS client ID registered in bridge's BRIDGE_ALLOWED_REDIRECT_URIS
POS_CLIENT_ID=carevibes-pos

# Secret for encrypting session cookies (generate with: openssl rand -hex 32)
POS_SESSION_SECRET=

# Public app URL (used for OAuth redirect_uri)
NEXT_PUBLIC_APP_URL=http://localhost:3000
